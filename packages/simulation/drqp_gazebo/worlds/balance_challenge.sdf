<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="balance_challenge">
    <physics name="physics" type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics" />
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands" />
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster" />
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gravity>0 0 -9.8</gravity>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.50 0.54 0.48 1</ambient>
            <diffuse>0.50 0.54 0.48 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="physics_seesaw">
      <static>false</static>
      <pose>-2.5 0 0 0 0 0</pose>

      <link name="fulcrum">
        <pose>0 0 0.18 1.5708 0 0</pose>
        <gravity>false</gravity>
        <inertial>
          <mass>200.0</mass>
          <inertia>
            <ixx>4.0</ixx>
            <iyy>4.0</iyy>
            <izz>4.0</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.18</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.18</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.28 0.31 0.34 1</ambient>
            <diffuse>0.28 0.31 0.34 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="pivot">
        <pose>0 0 0.38 0 0 0</pose>
        <gravity>false</gravity>
        <inertial>
          <mass>200.0</mass>
          <inertia>
            <ixx>4.0</ixx>
            <iyy>4.0</iyy>
            <izz>4.0</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
      </link>

      <link name="board">
        <pose>0 0 0.38 0 0.08 0</pose>
        <inertial>
          <pose>0.35 0 0 0 0 0</pose>
          <mass>18.0</mass>
          <inertia>
            <ixx>3.004</ixx>
            <iyy>24.019</iyy>
            <izz>27.000</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <box>
              <size>4.0 1.2 0.02</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>8.0</mu>
                <mu2>8.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>4.0 1.2 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.48 0.31 0.18 1</ambient>
            <diffuse>0.58 0.38 0.23 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="fulcrum_fixed" type="fixed">
        <parent>world</parent>
        <child>fulcrum</child>
      </joint>
      <joint name="pivot_fixed" type="fixed">
        <parent>world</parent>
        <child>pivot</child>
      </joint>
      <joint name="board_pivot" type="revolute">
        <parent>pivot</parent>
        <child>board</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-0.45</lower>
            <upper>0.45</upper>
          </limit>
          <dynamics>
            <damping>0.25</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>
    </model>

    <model name="motor_tilt_platform">
      <static>false</static>
      <pose>0.5 0 0 0 0 0</pose>

      <link name="base">
        <pose>0 0 0.011 0 0 0</pose>
        <inertial>
          <mass>150.0</mass>
          <inertia>
            <ixx>2.0</ixx>
            <iyy>2.0</iyy>
            <izz>2.0</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
      </link>

      <link name="platform">
        <pose>0 0 0.011 0 0 0</pose>
        <inertial>
          <mass>35.0</mass>
          <inertia>
            <ixx>5.728</ixx>
            <iyy>186.685</iyy>
            <izz>192.383</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <pose>2.0 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>4.0 1.4 0.02</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>8.0</mu>
                <mu2>8.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <pose>2.0 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>4.0 1.4 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.20 0.46 0.50 1</ambient>
            <diffuse>0.20 0.56 0.60 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="base_fixed" type="fixed">
        <parent>world</parent>
        <child>base</child>
      </joint>
      <joint name="tilt_hinge" type="revolute">
        <parent>base</parent>
        <child>platform</child>
        <axis>
          <xyz>0 -1 0</xyz>
          <limit>
            <lower>0.0</lower>
            <upper>0.349066</upper>
            <effort>2500.0</effort>
            <velocity>0.08</velocity>
          </limit>
          <dynamics>
            <damping>3.0</damping>
            <friction>0.2</friction>
          </dynamics>
        </axis>
      </joint>

      <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
        <joint_name>tilt_hinge</joint_name>
        <topic>/balance_challenge/motor_tilt_platform/target_position</topic>
        <p_gain>5000.0</p_gain>
        <i_gain>0.0</i_gain>
        <d_gain>300.0</d_gain>
        <cmd_max>10000.0</cmd_max>
        <cmd_min>-10000.0</cmd_min>
      </plugin>
    </model>

    <model name="pump_park_terrain">
      <static>true</static>
      <pose>0 3.0 0 0 0 0</pose>

      <link name="link">
        <visual name="approach_visual">
          <pose>-2.8 0 0.01 0 0 0</pose>
          <geometry>
            <box>
              <size>1.4 1.4 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.34 0.42 0.28 1</ambient>
            <diffuse>0.40 0.50 0.32 1</diffuse>
          </material>
        </visual>
        <collision name="approach_collision">
          <pose>-2.8 0 0.01 0 0 0</pose>
          <geometry>
            <box>
              <size>1.4 1.4 0.02</size>
            </box>
          </geometry>
        </collision>

        <collision name="hump_1_collision">
          <pose>-1.2 0 -0.52 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.64</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="hump_1_visual">
          <pose>-1.2 0 -0.52 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.64</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.34 0.42 0.28 1</ambient>
            <diffuse>0.40 0.50 0.32 1</diffuse>
          </material>
        </visual>

        <collision name="hump_2_collision">
          <pose>0 0 -0.52 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.68</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="hump_2_visual">
          <pose>0 0 -0.52 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.68</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.34 0.42 0.28 1</ambient>
            <diffuse>0.40 0.50 0.32 1</diffuse>
          </material>
        </visual>

        <collision name="hump_3_collision">
          <pose>1.2 0 -0.52 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.60</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="hump_3_visual">
          <pose>1.2 0 -0.52 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.60</radius>
              <length>1.4</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.34 0.42 0.28 1</ambient>
            <diffuse>0.40 0.50 0.32 1</diffuse>
          </material>
        </visual>

        <visual name="exit_visual">
          <pose>2.8 0 0.01 0 0 0</pose>
          <geometry>
            <box>
              <size>1.4 1.4 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.34 0.42 0.28 1</ambient>
            <diffuse>0.40 0.50 0.32 1</diffuse>
          </material>
        </visual>
        <collision name="exit_collision">
          <pose>2.8 0 0.01 0 0 0</pose>
          <geometry>
            <box>
              <size>1.4 1.4 0.02</size>
            </box>
          </geometry>
        </collision>
      </link>
    </model>

    <plugin filename="gz-sim-triggered-publisher-system" name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Clock" topic="/clock">
        <match field="sim.sec">10</match>
      </input>
      <output type="gz.msgs.Double" topic="/balance_challenge/motor_tilt_platform/target_position">
        data: 0.349066
