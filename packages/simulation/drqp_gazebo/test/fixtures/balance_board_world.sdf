<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="balance_test">
    <physics name="physics" type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics" />
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands" />
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster" />
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gravity>0 0 -9.8</gravity>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!--
      Pivoted balance board: anchor fixed to world at board center → roll_arm (X-axis
      revolute) → board (Y-axis revolute).  Two JointPositionControllers drive each axis
      gradually so the robot is never teleported into the surface.
    -->
    <model name="balance_board">
      <static>false</static>
      <pose>0 0 0 0 0 0</pose>

      <!-- Invisible anchor pinned to the world at the pivot point -->
      <link name="anchor">
        <pose>0 0 0.15 0 0 0</pose>
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.01</ixx>
            <iyy>0.01</iyy>
            <izz>0.01</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
      </link>

      <!-- Intermediate link that carries the roll rotation (around world X).
           Kept light: the JointPositionController supplies the holding torque, so
           large inertia is unnecessary and a heavy link only injects jitter that
           disturbs the robot standing on the board. -->
      <link name="roll_arm">
        <pose>0 0 0.15 0 0 0</pose>
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.05</ixx>
            <iyy>0.05</iyy>
            <izz>0.05</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
      </link>

      <!-- The actual board that the robot stands on. Kept light: the position
           controller holds the commanded angle, and a light board responds
           gently instead of jittering the robot's footing. -->
      <link name="board">
        <pose>0 0 0.15 0 0 0</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.05</ixx>
            <iyy>0.05</iyy>
            <izz>0.05</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.8 0.8 0.05</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>10.0</mu>
                <mu2>10.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.8 0.8 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.45 0.30 0.18 1</ambient>
            <diffuse>0.55 0.36 0.22 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Pin the anchor rigidly to the world -->
      <joint name="anchor_fixed" type="fixed">
        <parent>world</parent>
        <child>anchor</child>
      </joint>

      <!-- Roll axis: rotates roll_arm around world X -->
      <joint name="roll_hinge" type="revolute">
        <parent>anchor</parent>
        <child>roll_arm</child>
        <axis>
          <xyz>1 0 0</xyz>
          <limit>
            <lower>-0.25</lower>
            <upper>0.25</upper>
            <effort>1000.0</effort>
            <velocity>0.1</velocity>
          </limit>
          <dynamics>
            <damping>2.0</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- Pitch axis: rotates board around roll_arm's Y -->
      <joint name="pitch_hinge" type="revolute">
        <parent>roll_arm</parent>
        <child>board</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-0.25</lower>
            <upper>0.25</upper>
            <effort>1000.0</effort>
            <velocity>0.1</velocity>
          </limit>
          <dynamics>
            <damping>2.0</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- Gradually drive the roll joint to the commanded angle -->
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>roll_hinge</joint_name>
        <topic>/balance_board/roll_target</topic>
        <p_gain>1500.0</p_gain>
        <i_gain>0.0</i_gain>
        <d_gain>50.0</d_gain>
        <cmd_max>2000.0</cmd_max>
        <cmd_min>-2000.0</cmd_min>
      </plugin>

      <!-- Gradually drive the pitch joint to the commanded angle -->
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>pitch_hinge</joint_name>
        <topic>/balance_board/pitch_target</topic>
        <p_gain>1500.0</p_gain>
        <i_gain>0.0</i_gain>
        <d_gain>50.0</d_gain>
        <cmd_max>2000.0</cmd_max>
        <cmd_min>-2000.0</cmd_min>
      </plugin>
    </model>
  </world>
</sdf>
