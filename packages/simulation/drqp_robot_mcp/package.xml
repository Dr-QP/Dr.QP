<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>drqp_robot_mcp</name>
  <version>0.1.0</version>
  <description>MCP server package for interacting with the Dr.QP simulation.</description>
  <maintainer email="anton.matosov@gmail.com">Anton Matosov</maintainer>
  <license>MIT</license>

  <exec_depend>drqp_brain</exec_depend>
  <exec_depend>drqp_gazebo</exec_depend>
  <exec_depend>drqp_interfaces</exec_depend>
  <exec_depend>python3-ament-index-python</exec_depend>
  <exec_depend>geometry_msgs</exec_depend>
  <exec_depend>nav_msgs</exec_depend>
  <exec_depend>rclpy</exec_depend>
  <exec_depend>ros2launch</exec_depend>
  <exec_depend>rosgraph_msgs</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>std_msgs</exec_depend>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
