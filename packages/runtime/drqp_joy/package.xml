<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>drqp_joy</name>
  <version>1.0.0</version>
  <description>Dr.QP game controller node — SDL3 port with full dual-motor rumble and haptic support</description>
  <maintainer email="anton.matosov@gmail.com">Anton Matosov</maintainer>
  <license>BSD-3-Clause AND MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>rclcpp_components</depend>
  <depend>sensor_msgs</depend>
  <depend>drqp_interfaces</depend>

  <!-- SDL3: apt install libsdl3-dev (Ubuntu 24.04+) -->
  <build_depend>libsdl3-dev</build_depend>
  <exec_depend>libsdl3-dev</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>drqp_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
