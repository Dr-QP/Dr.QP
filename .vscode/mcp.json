{
  "servers": {
    "sequentialthinking": {
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp/oauth"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "MCP_DOCKER": {
      "type": "sse",
      "url": "http://localhost:8811/sse"
    },
    "drqp_robot": {
      "type": "stdio",
      "command": "${workspaceFolder}/.venv/bin/drqp_robot_mcp",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
