{
  "servers": {
    "sequentialthinking": {
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "mcp-docs": {
      "type": "http",
      "url": "https://modelcontextprotocol.io/mcp"
    },
    "mcp-server-git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp/oauth",
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "augmentcode": {
      "type": "stdio",
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ]
    }
  }
}
