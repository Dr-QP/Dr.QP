{
  "name": "Dr.QP ROS 2 jazzy",
  "initializeCommand": ".devcontainer/devcontainer-init.sh",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        // Open the /opt/ros/overlay_ws/Dr.QP.code-workspace to install the recommended extensions
      ]
    }
  },
  "workspaceFolder": "/opt/ros/overlay_ws/",
  "containerEnv": {
    "DISPLAY": ":100",
    "DOCKER_HOST": "unix:///var/run/docker.sock",
    "DEVCONTAINER_ID": "${devcontainerId}"
  },

  "forwardPorts": ["14500-14599"],
  "portsAttributes": {
    "14500-14599": {
      "label": "Xpra HTML5",
      "onAutoForward": "silent"
    }
  },
  "mounts": [
    // Shared .vscode folder
    {
      "source": "drqp-vscode",
      "target": "${workspaceFolder}/.vscode",
      "type": "volume"
    },

    {
      "source": "drqp-ansible-${devcontainerId}",
      "target": "${workspaceFolder}/.ansible",
      "type": "volume"
    },
    {
      "source": "drqp-clangd-cache-${devcontainerId}",
      "target": "${workspaceFolder}/.cache",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-build-${devcontainerId}",
      "target": "${workspaceFolder}/build",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-install-${devcontainerId}",
      "target": "${workspaceFolder}/install",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-lcov-${devcontainerId}",
      "target": "${workspaceFolder}/lcov",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-log-${devcontainerId}",
      "target": "${workspaceFolder}/log",
      "type": "volume"
    },
    {
      "source": "drqp-docs-build-${devcontainerId}",
      "target": "${workspaceFolder}/docs/_build",
      "type": "volume"
    },
    {
      "source": "drqp-python-micromamba-${devcontainerId}",
      "target": "${workspaceFolder}/.micromamba",
      "type": "volume"
    },
    {
      "source": "drqp-python-venv-${devcontainerId}",
      "target": "${workspaceFolder}/.venv",
      "type": "volume"
    },
    {
      "source": "drqp-python-venv-prod-${devcontainerId}",
      "target": "${workspaceFolder}/.venv-prod",
      "type": "volume"
    }
  ],
  // Second venv command with --system-site-packages turns on access to system packages to allow ROS2 builds to work
  "postCreateCommand": "sudo chown -R root:root /opt/ros/overlay_ws/.ansible /opt/ros/overlay_ws/.vscode /opt/ros/overlay_ws/.cache /opt/ros/overlay_ws/build /opt/ros/overlay_ws/install /opt/ros/overlay_ws/lcov /opt/ros/overlay_ws/log /opt/ros/overlay_ws/docs/_build /opt/ros/overlay_ws/.micromamba /opt/ros/overlay_ws/.venv /opt/ros/overlay_ws/.venv-prod",
  "postAttachCommand": {
    "git config": "git config --global gpg.ssh.program ssh-keygen",
    "python-venv": "python3 -m venv /opt/ros/overlay_ws/.venv && /opt/ros/overlay_ws/.venv/bin/python3 -m pip install -r /opt/ros/overlay_ws/requirements.txt --use-pep517", // Keep in sync with the task in Dr.QP.code-workspace
    "rosdep": "./scripts/ros-dep.sh"
  },
  "postStartCommand": "./scripts/devcontainer-postStartCommand.sh"
}
