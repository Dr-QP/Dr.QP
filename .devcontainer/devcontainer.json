{
  "name": "Dr.QP ROS 2 jazzy",
  "initializeCommand": ".devcontainer/devcontainer-init.sh",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        // Open the /opt/ros/overlay_ws/Dr.QP.code-workspace to install the recommended extensions
      ]
    }
  },
  "workspaceFolder": "/opt/ros/overlay_ws/",
  "containerEnv": {
    "ENABLE_FIREWALL": "false",

    "DISPLAY": ":100",
    "DOCKER_HOST": "unix:///var/run/docker.sock",
    "DEVCONTAINER_ID": "${devcontainerId}",

    "UV_CACHE_DIR": "/uv/cache",
    "UV_PYTHON_INSTALL_DIR": "/uv/python",
    "UV_PROJECT_ENVIRONMENT": "/uv/venvs/${localWorkspaceFolderBasename}/"
  },

  "forwardPorts": ["14500-14599"],
  "portsAttributes": {
    "14500-14599": {
      "label": "Xpra HTML5",
      "onAutoForward": "silent"
    }
  },
  "mounts": [
    {
      "source": "drqp-ansible",
      "target": "/opt/ros/overlay_ws/.ansible",
      "type": "volume"
    },
    {
      "source": "drqp-clangd-cache",
      "target": "/opt/ros/overlay_ws/.cache",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-build",
      "target": "/opt/ros/overlay_ws/build",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-install",
      "target": "/opt/ros/overlay_ws/install",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-lcov",
      "target": "/opt/ros/overlay_ws/lcov",
      "type": "volume"
    },
    {
      "source": "drqp-colcon-log",
      "target": "/opt/ros/overlay_ws/log",
      "type": "volume"
    },
    {
      "source": "drqp-docs-build",
      "target": "/opt/ros/overlay_ws/docs/_build",
      "type": "volume"
    },
    {
      "source": "drqp-python-micromamba",
      "target": "/opt/ros/overlay_ws/.micromamba",
      "type": "volume"
    },
    {
      "source": "drqp-uv",
      "target": "/uv",
      "type": "volume"
    },
    {
      "source": "drqp-python-venv-prod",
      "target": "/opt/ros/overlay_ws/.venv-prod",
      "type": "volume"
    }
  ],
  // Keep the developer `.venv` bootstrap separate from the ROS runtime `.venv-prod` flow.
  "postCreateCommand": "sudo chown -R root:root /opt/ros/overlay_ws/.ansible /opt/ros/overlay_ws/.vscode /opt/ros/overlay_ws/.cache /opt/ros/overlay_ws/build /opt/ros/overlay_ws/install /opt/ros/overlay_ws/lcov /opt/ros/overlay_ws/log /opt/ros/overlay_ws/docs/_build /opt/ros/overlay_ws/.micromamba /uv /opt/ros/overlay_ws/.venv-prod",
  "postAttachCommand": {
    "git config": "git config --global gpg.ssh.program ssh-keygen",
    "python-venv": "./scripts/uv-sync.sh",
    "rosdep": "./scripts/ros-dep.sh"
  },
  "postStartCommand": "./scripts/devcontainer-postStartCommand.sh"
}
